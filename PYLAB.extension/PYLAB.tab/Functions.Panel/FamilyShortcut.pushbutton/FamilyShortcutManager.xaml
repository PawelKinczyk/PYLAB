<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FamilyShortcut Manager"
    Height="760"
    Width="1360"
    MinHeight="620"
    MinWidth="1180"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#FFF6F6F6">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFD2D2D2"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Shortcut Assignments" />
                    <TextBox x:Name="search_tb"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             Height="30"
                             VerticalContentAlignment="Center"
                             ToolTip="Filter by shortcut, family, type, or category" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFD2D2D2"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Add From Active Document" />
                    <TextBox x:Name="picker_search_tb"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             Height="30"
                             VerticalContentAlignment="Center"
                             ToolTip="Filter family types found in the active model" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#FFD2D2D2"
                    BorderThickness="1"
                    CornerRadius="4">
                <DataGrid x:Name="assignment_grid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          AlternatingRowBackground="#FFF9F9F9"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Shortcut"
                                            Width="90"
                                            Binding="{Binding Shortcut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Family Name"
                                            Width="230"
                                            Binding="{Binding FamilyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Type Name"
                                            Width="230"
                                            Binding="{Binding TypeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Category"
                                            Width="180"
                                            Binding="{Binding CategoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridCheckBoxColumn Header="Enabled"
                                                Width="90"
                                                Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#FFD2D2D2"
                    BorderThickness="1"
                    CornerRadius="4">
                <DataGrid x:Name="symbol_grid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          AlternatingRowBackground="#FFF9F9F9"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Family Name"
                                            Width="260"
                                            Binding="{Binding FamilyName}" />
                        <DataGridTextColumn Header="Type Name"
                                            Width="260"
                                            Binding="{Binding TypeName}" />
                        <DataGridTextColumn Header="Category"
                                            Width="180"
                                            Binding="{Binding CategoryName}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Grid.Row="2"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Padding="10,8"
                        Background="#FFF2F5F7"
                        BorderBrush="#FFD2D2D2"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock x:Name="status_tb"
                               TextWrapping="Wrap"
                               Text="Ready." />
                </Border>
                <Border Margin="0,8,0,0"
                        Padding="10,8"
                        Background="#FFFCF3D8"
                        BorderBrush="#FFE3D6A1"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock x:Name="validation_tb"
                               TextWrapping="Wrap"
                               Text="No validation errors." />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button x:Name="add_manual_btn"
                        Width="110"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Add Manual" />
                <Button x:Name="remove_selected_btn"
                        Width="120"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Remove Selected" />
                <Button x:Name="reload_doc_btn"
                        Width="120"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Reload Model" />
                <Button x:Name="add_from_doc_btn"
                        Width="135"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Add From Model" />
                <Button x:Name="save_btn"
                        Width="90"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Save" />
                <Button x:Name="close_btn"
                        Width="90"
                        Height="32"
                        Content="Close" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
