<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Place in Rooms / Spaces"
    Height="780"
    Width="1240"
    MinHeight="620"
    MinWidth="1080"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    Background="#FFF6F6F6">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,10"
                Background="White"
                BorderBrush="#FFD2D2D2"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <RadioButton x:Name="mode_rooms_rb"
                                 Content="Rooms only"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center" />
                    <RadioButton x:Name="mode_spaces_rb"
                                 Content="Spaces only"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center" />
                    <RadioButton x:Name="mode_both_rb"
                                 Content="Both"
                                 IsChecked="True"
                                 VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="Search:" />

                <TextBox x:Name="search_tb"
                         Grid.Column="4"
                         Height="28"
                         VerticalContentAlignment="Center"
                         ToolTip="Filter by number, name, or level" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="12"
                Margin="0,0,0,10"
                Background="White"
                BorderBrush="#FFD2D2D2"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            MaxWidth="320">
                    <TextBlock FontWeight="SemiBold" Text="Family assignment" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FF555555"
                               TextWrapping="Wrap"
                               Text="Choose a family type in each selected row, or use Shift/Ctrl row selection and assign one family to all selected rows." />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Bottom">
                    <TextBlock FontWeight="SemiBold" Text="Assign selected rows" />
                    <ComboBox x:Name="bulk_family_combo"
                              Margin="0,4,0,0"
                              MinWidth="260"
                              Height="30"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <Button x:Name="assign_family_btn"
                        Grid.Column="4"
                        Width="110"
                        Height="30"
                        VerticalAlignment="Bottom"
                        Content="Assign Family" />

                <StackPanel Grid.Column="6"
                            VerticalAlignment="Bottom">
                    <TextBlock FontWeight="SemiBold" Text="X offset" />
                    <TextBox x:Name="x_offset_tb"
                             Margin="0,4,0,0"
                             Width="90"
                             Height="30"
                             Text="0" />
                </StackPanel>

                <StackPanel Grid.Column="8"
                            VerticalAlignment="Bottom">
                    <TextBlock FontWeight="SemiBold" Text="Y offset" />
                    <TextBox x:Name="y_offset_tb"
                             Margin="0,4,0,0"
                             Width="90"
                             Height="30"
                             Text="0" />
                </StackPanel>

                <StackPanel Grid.Column="10"
                            VerticalAlignment="Bottom">
                    <TextBlock FontWeight="SemiBold" Text="Z offset" />
                    <TextBox x:Name="z_offset_tb"
                             Margin="0,4,0,0"
                             Width="90"
                             Height="30"
                             Text="0" />
                </StackPanel>

                <TextBlock x:Name="units_tb"
                           Grid.Column="12"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,6"
                           Foreground="#FF555555"
                           TextWrapping="Wrap"
                           Width="150"
                           Text="Project length unit" />

                <Button x:Name="check_all_btn"
                        Grid.Column="14"
                        Width="95"
                        Height="30"
                        Content="Check All"
                        VerticalAlignment="Bottom" />

                <Button x:Name="uncheck_all_btn"
                        Grid.Column="16"
                        Width="95"
                        Height="30"
                        Content="Uncheck All"
                        VerticalAlignment="Bottom" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD2D2D2"
                BorderThickness="1"
                CornerRadius="4">
            <DataGrid x:Name="spatial_grid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#FFF9F9F9"
                      BorderThickness="0"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Select"
                                            Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Type"
                                        Width="90"
                                        IsReadOnly="True"
                                        Binding="{Binding SpatialType}" />
                    <DataGridTextColumn Header="Number"
                                        Width="110"
                                        IsReadOnly="True"
                                        Binding="{Binding Number}" />
                    <DataGridTextColumn Header="Name"
                                        Width="220"
                                        IsReadOnly="True"
                                        Binding="{Binding Name}" />
                    <DataGridTemplateColumn Header="Family Type"
                                            Width="270">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding FamilyOptions}"
                                          SelectedItem="{Binding SelectedFamilyOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="240" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Level"
                                        Width="150"
                                        IsReadOnly="True"
                                        Binding="{Binding LevelName}" />
                    <DataGridTextColumn Header="Element Id"
                                        Width="95"
                                        IsReadOnly="True"
                                        Binding="{Binding ElementIdValue}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10,8"
                    Background="#FFF2F5F7"
                    BorderBrush="#FFD2D2D2"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock x:Name="status_tb"
                           Foreground="#FF555555"
                           Text="Ready."
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="export_excel_btn"
                        Width="110"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Export Excel" />
                <Button x:Name="import_excel_btn"
                        Width="110"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Import Excel" />
                <Button x:Name="apply_btn"
                        Width="95"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Apply" />
                <Button x:Name="cancel_btn"
                        Width="95"
                        Height="32"
                        Content="Cancel" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
